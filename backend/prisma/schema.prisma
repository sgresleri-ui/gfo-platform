generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./gfo.db"
}

model Household {
  id                       Int                       @id @default(autoincrement())
  name                     String
  currency                 String                    @default("EUR")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  wealthPositions          WealthPosition[]
  wealthTransactions       WealthTransaction[]
  netWorthSnapshots        NetWorthSnapshot[]
  operationalTasks         OperationalTask[]
  documents                DocumentRecord[]
  executiveReportSnapshots ExecutiveReportSnapshot[]
  planningScenarios        PlanningScenario[]
}

model Institution {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  country   String
  type      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
}

model Account {
  id            Int         @id @default(autoincrement())
  name          String
  code          String      @unique
  currency      String
  balance       Float       @default(0)
  institutionId Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id])
}

model WealthPosition {
  id                            Int                            @id @default(autoincrement())
  householdId                   Int
  code                          String                         @unique
  name                          String
  category                      String
  subcategory                   String?
  country                       String?
  currency                      String                         @default("EUR")
  nativeAmount                  Decimal?
  fxRateToBase                  Decimal?
  valueBase                     Decimal
  baseCurrency                  String                         @default("EUR")
  isLiability                   Boolean                        @default(false)
  valuationDate                 DateTime
  source                        String                         @default("MANUAL")
  status                        String                         @default("ACTIVE")
  notes                         String?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  household                     Household                      @relation(fields: [householdId], references: [id])
  transactions                  WealthTransaction[]
  valuations                    PositionValuation[]
  ipsClassification             IpsPositionClassification?
  ipsClassificationAudits       IpsClassificationAudit[]
  ipsClassificationReview       IpsClassificationReview?
  ipsClassificationReviewAudits IpsClassificationReviewAudit[]

  @@index([householdId, category])
  @@index([valuationDate])
}

model PlatformSetting {
  id                     Int      @id @default(1)
  householdName          String   @default("Family Office – Stefano Gresleri")
  ownerName              String   @default("Stefano Gresleri")
  baseCurrency           String   @default("EUR")
  timezone               String   @default("Europe/Madrid")
  fiscalResidence        String   @default("Spain")
  plannedFiscalResidence String   @default("United Arab Emirates")
  sourceWorkbook         String   @default("Gresleri2026.xlsm")
  dataFolder             String   @default("/data")
  automaticRefresh       Boolean  @default(true)
  showArchivedPositions  Boolean  @default(false)
  requireDecisionNotes   Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model DecisionLogEntry {
  id               String   @id
  decisionDate     DateTime
  title            String
  category         String
  status           String
  priority         String
  motivation       String
  analysisText     String
  alternativesJson String
  finalDecision    String
  impact           String
  amount           Float?
  resultText       String
  lessons          String
  source           String   @default("MANUAL")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([decisionDate])
  @@index([status])
  @@index([priority])
}

model ImportRun {
  id                 String    @id @default(cuid())
  fileName           String
  filePath           String
  fileHash           String
  fileSize           Int
  workbookModifiedAt DateTime?
  status             String
  sheetCount         Int       @default(0)
  activePositions    Int       @default(0)
  archivedPositions  Int       @default(0)
  previewJson        String    @default("{}")
  errorMessage       String?
  createdAt          DateTime  @default(now())
  completedAt        DateTime?

  @@index([fileHash])
  @@index([status])
  @@index([createdAt])
}

model WealthSnapshot {
  id                String    @id @default(cuid())
  snapshotType      String
  reason            String
  sourceRunId       String?
  positionsJson     String
  activePositions   Int
  archivedPositions Int
  netValue          Float
  createdAt         DateTime  @default(now())
  restoredAt        DateTime?

  @@index([sourceRunId])
  @@index([createdAt])
}

model WealthTransaction {
  id                     String          @id @default(cuid())
  householdId            Int
  positionId             Int?
  transactionDate        DateTime
  transactionType        String
  direction              String
  quantity               Decimal?
  unitPrice              Decimal?
  grossAmount            Decimal
  fees                   Decimal         @default(0)
  taxes                  Decimal         @default(0)
  netAmount              Decimal
  currency               String          @default("EUR")
  fxRateToBase           Decimal?
  baseAmount             Decimal
  baseCurrency           String          @default("EUR")
  sourceAccountCode      String?
  destinationAccountCode String?
  source                 String          @default("MANUAL")
  status                 String          @default("POSTED")
  externalReference      String?
  notes                  String?
  voidedAt               DateTime?
  voidReason             String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  household              Household       @relation(fields: [householdId], references: [id])
  position               WealthPosition? @relation(fields: [positionId], references: [id])

  @@index([householdId, transactionDate])
  @@index([positionId, transactionDate])
  @@index([transactionType])
  @@index([externalReference])
}

model NetWorthSnapshot {
  id            String              @id @default(cuid())
  householdId   Int
  snapshotDate  DateTime
  source        String
  importRunId   String?
  dataHash      String              @unique
  positionCount Int
  grossAssets   Decimal
  liabilities   Decimal
  netWorth      Decimal
  liquidity     Decimal
  investments   Decimal
  realEstate    Decimal
  otherAssets   Decimal
  createdAt     DateTime            @default(now())
  household     Household           @relation(fields: [householdId], references: [id])
  valuations    PositionValuation[]

  @@index([householdId, snapshotDate])
  @@index([snapshotDate])
  @@index([importRunId])
}

model PositionValuation {
  id                  String           @id @default(cuid())
  positionId          Int
  snapshotId          String
  valuationDate       DateTime
  sourceValuationDate DateTime?
  nativeAmount        Decimal?
  currency            String
  fxRateToBase        Decimal?
  valueBase           Decimal
  baseCurrency        String           @default("EUR")
  source              String
  createdAt           DateTime         @default(now())
  position            WealthPosition   @relation(fields: [positionId], references: [id])
  snapshot            NetWorthSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([positionId, snapshotId])
  @@index([positionId, valuationDate])
  @@index([snapshotId])
  @@index([valuationDate])
}

model DataQualityCorrection {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  entityCode String?
  fieldName  String
  oldValue   String?
  newValue   String
  reason     String
  source     String   @default("USER_CONFIRMED")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([fieldName, createdAt])
}

model IpsPolicyLimit {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  label     String
  dimension String
  unit      String   @default("PERCENT")
  minimum   Float?
  maximum   Float?
  target    Float?
  enabled   Boolean  @default(false)
  rationale String?
  source    String   @default("IPS_CONFIRMED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dimension, enabled])
}

model IpsPositionClassification {
  id            Int      @id @default(autoincrement())
  positionId    Int      @unique
  ipsAssetClass String
  source        String   @default("USER_CONFIRMED")
  rationale     String?
  confirmed     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  position WealthPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([ipsAssetClass])
}

model IpsClassificationAudit {
  id           Int      @id @default(autoincrement())
  positionId   Int
  positionCode String
  oldClass     String?
  newClass     String
  reason       String
  source       String   @default("USER_CONFIRMED")
  createdAt    DateTime @default(now())

  position WealthPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@index([newClass])
}

model IpsClassificationReview {
  id         Int      @id @default(autoincrement())
  positionId Int      @unique
  status     String
  note       String
  source     String   @default("USER_CONFIRMED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  position WealthPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([status])
}

model IpsClassificationReviewAudit {
  id           Int      @id @default(autoincrement())
  positionId   Int
  positionCode String
  oldStatus    String?
  newStatus    String
  note         String
  source       String   @default("USER_CONFIRMED")
  createdAt    DateTime @default(now())

  position WealthPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@index([newStatus])
}

model OperationalTask {
  id                  String    @id @default(cuid())
  householdId         Int
  dueDate             DateTime
  title               String
  category            String
  status              String    @default("TODO")
  priority            String    @default("MEDIUM")
  description         String
  linkedDocumentsJson String    @default("[]")
  amount              Float?
  notes               String?
  source              String    @default("MANUAL")
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  household Household @relation(fields: [householdId], references: [id])

  @@index([householdId, dueDate])
  @@index([status])
  @@index([priority])
  @@index([category])
}

model DocumentRecord {
  id              String    @id @default(cuid())
  householdId     Int
  title           String
  category        String
  documentType    String
  status          String    @default("ACTIVE")
  issuer          String?
  country         String?
  documentNumber  String?
  issueDate       DateTime?
  expiryDate      DateTime?
  fileName        String?
  filePath        String?
  mimeType        String?
  fileSize        Int?
  checksum        String?
  confidentiality String    @default("PRIVATE")
  notes           String?
  source          String    @default("MANUAL")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  household Household      @relation(fields: [householdId], references: [id])
  links     DocumentLink[]

  @@index([householdId, category])
  @@index([status])
  @@index([expiryDate])
  @@index([country])
  @@index([checksum])
}

model DocumentLink {
  id           String   @id @default(cuid())
  documentId   String
  entityType   String
  entityId     String
  relationType String   @default("SUPPORTING")
  notes        String?
  createdAt    DateTime @default(now())

  document DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, entityType, entityId])
  @@index([entityType, entityId])
}

model ExecutiveReportSnapshot {
  id                     String   @id @default(cuid())
  householdId            Int
  reportType             String
  version                String
  status                 String
  generatedAt            DateTime
  completenessPercentage Float
  totalSections          Int
  availableSections      Int
  unavailableSections    Int
  netWorth               Decimal?
  grossAssets            Decimal?
  liabilities            Decimal?
  liquidity              Decimal?
  investments            Decimal?
  realEstate             Decimal?
  otherAssets            Decimal?
  currency               String   @default("EUR")
  payloadJson            String
  checksum               String   @unique
  source                 String   @default("REPORTING_ENGINE")
  createdAt              DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])

  @@index([householdId, createdAt])
  @@index([generatedAt])
  @@index([status])
  @@index([reportType])
}

model PlanningScenario {
  id                       String    @id @default(cuid())
  householdId              Int
  name                     String
  description              String?
  status                   String    @default("ACTIVE")
  assumptionsJson          String

  economicProfileId           String?
  economicProfileCode         String?
  economicProfileName         String?
  economicProfileSnapshotJson String?

  lastResultJson           String?
  baselineWorkbook         String?
  baselineAsOfDate         String?
  baselineStartYear        Int?
  baselineEndYear          Int?
  sustainabilityStatus     String?
  initialCapital           Decimal?
  finalCapital             Decimal?
  minimumCapital           Decimal?
  minimumCapitalYear       Int?
  firstNegativeCapitalYear Int?
  finalCapitalDelta        Decimal?
  finalCapitalDeltaPct     Float?
  lastSimulatedAt          DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  household Household @relation(fields: [householdId], references: [id])

  @@index([householdId, status])
  @@index([householdId, updatedAt])
  @@index([sustainabilityStatus])
  @@index([economicProfileId])
}

model EconomicAssumptionProfile {
  id              String @id @default(cuid())
  code            String @unique
  name            String
  description     String @default("")
  fiscalResidence String @default("Spain")

  liquidityReturnDeltaPct   Float @default(0)
  investmentsReturnDeltaPct Float @default(0)
  realEstateReturnDeltaPct  Float @default(0)
  otherAssetsReturnDeltaPct Float @default(0)

  liquidityTaxRatePct   Float @default(0)
  investmentsTaxRatePct Float @default(0)

  rebalancingCostRatePct Float @default(0)
  rebalancingMinimumCost Float @default(0)

  isDefault  Boolean @default(false)
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fiscalResidence])
  @@index([isDefault])
  @@index([isArchived])
}
