generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./gfo.db"
}

model Household {
  id              Int              @id @default(autoincrement())
  name            String
  currency        String           @default("EUR")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  wealthPositions WealthPosition[]
}

model Institution {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  country   String
  type      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
}

model Account {
  id            Int         @id @default(autoincrement())
  name          String
  code          String      @unique
  currency      String
  balance       Float       @default(0)
  institutionId Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id])
}

model WealthPosition {
  id            Int       @id @default(autoincrement())
  householdId   Int
  code          String    @unique
  name          String
  category      String
  subcategory   String?
  country       String?
  currency      String    @default("EUR")
  nativeAmount  Decimal?
  fxRateToBase  Decimal?
  valueBase     Decimal
  baseCurrency  String    @default("EUR")
  isLiability   Boolean   @default(false)
  valuationDate DateTime
  source        String    @default("MANUAL")
  status        String    @default("ACTIVE")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  household     Household @relation(fields: [householdId], references: [id])

  @@index([householdId, category])
  @@index([valuationDate])
}
